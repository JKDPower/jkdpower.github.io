# Normalize line endings to LF in the repository for all text files.
# Git stores LF; this prevents the whole tree from showing as "modified"
# when files are checked out / re-saved with CRLF on Windows.
* text=auto eol=lf

# Explicit text types (kept LF in repo and in the working tree)
*.md       text eol=lf
*.markdown text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.svg      text eol=lf
*.rb       text eol=lf
*.txt      text eol=lf
Gemfile    text eol=lf
*.lock     text eol=lf

# Windows-specific scripts should keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary assets — never touch these (no EOL conversion, no diffing as text)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.pdf  binary
*.mp4  binary
*.mov  binary
*.zip  binary
